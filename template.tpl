___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const injectScript = require('injectScript');
const setDefaultConsentState = require('setDefaultConsentState');
const gtagSet = require('gtagSet');
const makeNumber = require('makeNumber');
const encodeUriComponent = require('encodeUriComponent');
const queryPermission = require('queryPermission');

const cbid = data.cbid;
const url = 'https://cdn.masterofcookies.eu/cmp/widget.js?cbid=' + encodeUriComponent(cbid);

// 1. Synchronous default consent state (denied) BEFORE any tag fires.
//    The Master of Cookies widget runs `consent update` after the user chooses;
//    here we only guarantee correct GTM timing with denied defaults.
if (data.consentModeEnabled !== false) {
  const wait = makeNumber(data.waitForUpdate) || 2000;
  const regions = data.regionSettings || [];
  let hasGlobal = false;

  const regionArr = (str) => {
    if (!str) { return []; }
    return str.split(',').map((r) => r.trim()).filter((r) => r.length !== 0);
  };

  regions.forEach((row) => {
    const state = {
      ad_storage: row.defaultConsentMarketing,
      ad_user_data: row.defaultAdUserData,
      ad_personalization: row.defaultAdPersonalization,
      analytics_storage: row.defaultConsentStatistics,
      functionality_storage: row.defaultConsentPreferences,
      personalization_storage: row.defaultConsentPreferences,
      security_storage: 'granted',
      wait_for_update: wait
    };
    const codes = regionArr(row.region);
    if (codes.length) {
      state.region = codes;
    } else {
      hasGlobal = true;
    }
    setDefaultConsentState(state);
  });

  // Global fallback (opt-out) if no blank-region row was provided.
  if (!hasGlobal) {
    setDefaultConsentState({
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
      analytics_storage: 'denied',
      functionality_storage: 'denied',
      personalization_storage: 'denied',
      security_storage: 'granted',
      wait_for_update: wait
    });
  }

  if (queryPermission('access_globals', 'readwrite', 'dataLayer')) {
    gtagSet('url_passthrough', data.urlPassthrough === true);
    gtagSet('ads_data_redaction', data.adsDataRedaction !== false);
  }
}

// 2. Load the shared Master of Cookies banner (handles consent update + script blocking).
if (queryPermission('inject_script', url)) {
  injectScript(url, data.gtmOnSuccess, data.gtmOnFailure, url);
} else {
  data.gtmOnFailure();
}


